# Скопируйте этот файл как secrets.yaml и заполните значения.
# secrets.yaml НЕ должен попадать в git.
#
# Wi‑Fi SSID/пароль в secrets НЕ нужны и НЕ должны попадать в прошивку.
# Сеть задаётся после флеша через captive portal:
#   AP SSID: TH-Sens-Setup
#   AP password: password
#
# Для Home Assistant нужен только api_encryption_key (отображается в веб‑UI).
# ota_password — только для ESPHome OTA, в HA не вводится.

# Ключ шифрования Native API для Home Assistant (Noise protocol).
# Сгенерировать:
#   openssl rand -base64 32
# Или взять сгенерированный ключ на странице:
#   https://esphome.io/components/api/
api_encryption_key: "YOUR_BASE64_32BYTE_KEY"

# Пароль OTA (обновление по воздуху, порт 8266). Не нужен для HA.
ota_password: "YOUR_OTA_PASSWORD"
